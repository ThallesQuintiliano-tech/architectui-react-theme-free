{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "checkJs": false,
    "allowJs": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"]
    },
    "types": ["vite/client", "vitest/globals", "node"]
  },
  "include": [
    "src",
    "e2e",
    "vite.config.js",
    "vitest.config.js",
    "vitest.setup.js",
    "playwright.config.js",
    "eslint.config.js"
  ],
  "exclude": ["node_modules", "build", "public"]
}
